# LLM Provider Configuration
# Choose which LLM provider to use: "openai", "anthropic", or "gemini"
LLM_PROVIDER=openai

# OpenAI Configuration (if using OpenAI)
# This key is also used for server-side fallback when the client does not send an api_key.
OPENAI_API_KEY=sk-your-openai-key-here
# Available models: gpt-5.4-nano, gpt-5.4-mini, gpt-5.4, gpt-5.2
LLM_MODEL=gpt-5.4-nano

# Anthropic Configuration (if using Claude)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
# Available models: claude-sonnet-4-5-20250929, claude-3-5-sonnet-20241022, claude-3-opus-20240229, claude-3-sonnet-20240229, claude-3-haiku-20240307
# LLM_MODEL=claude-sonnet-4-5-20250929

# Optional: Specify a different model for long-context operations
# If not set, uses the same as LLM_MODEL
LLM_LONG_CONTEXT_MODEL=gpt-5.4-nano

# Quick Setup Examples:
# 
# To use OpenAI GPT-5.4 Nano (recommended default):
#   LLM_PROVIDER=openai
#   OPENAI_API_KEY=sk-...
#   LLM_MODEL=gpt-5.4-nano
#
# To use Anthropic Claude 3.5 Sonnet:
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-5-20250929
#
# To use cheaper/faster alternatives:
#   OpenAI: LLM_MODEL=gpt-5.4-mini
#   Claude: LLM_MODEL=claude-3-haiku-20240307
